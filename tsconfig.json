{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/store/*": [
        "./src/store/*"
      ],
      "@/printing/*": [
        "./src/printing/*"
      ],
      "@/api/*": [
        "./src/api/*"
      ],
      "@/types": [
        "./src/types"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
