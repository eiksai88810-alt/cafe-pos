# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Source files
*.js        text eol=lf
*.jsx       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.env       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.gitignore text eol=lf
*.lock      text eol=lf

# Expo / React Native specific
app.json    text eol=lf
eas.json    text eol=lf

# Binary files — no conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.otf  binary
*.zip  binary
*.mp4  binary
*.webp binary
